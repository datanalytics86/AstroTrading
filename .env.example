# --- Auth (single-user private access) ---
# Plain password used by the Streamlit login gate.
# In production prefer a bcrypt hash via scripts/hash_password.py
ASTROTRADING_USERNAME=owner
ASTROTRADING_PASSWORD=change-me-now

# --- LLM agents (optional — narratives fall back to templates if unset) ---
# Preferred: xAI Grok
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# Fallback OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# --- Market data (optional) ---
# Polygon free tier improves reliability; yfinance is the default free source
POLYGON_API_KEY=

# --- App ---
ASTROTRADING_FRAME=heliocentric
ASTROTRADING_INDEX_START=2000-01-01
